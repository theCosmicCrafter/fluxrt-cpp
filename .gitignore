*.pyc
.venv/
venv/
.uv/
*.egg-info/

# Calibration data (large, regenerate if needed)
calibration_data/
tests/fixtures/*.bin
tests/fixtures/*.npy
tests/fixtures/*.pt
!tests/fixtures/.gitkeep
!tests/fixtures/README.md

