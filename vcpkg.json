{
  "name": "fluxrt-cpp",
  "version-string": "0.1.0-phase0",
  "description": "Real-time FLUX.2 stream editing in C++ with TensorRT",
  "homepage": "https://github.com/theCosmicCrafter/fluxrt-cpp",
  "license": "Apache-2.0",
  "supports": "(windows | linux) & x64",
  "dependencies": [
    "nlohmann-json",
    "fmt",
    "spdlog",
    "catch2",
    "stb"
  ],
  "features": {
    "io": {
      "description": "Webcam / video file I/O (Phase 3+). Pulls in OpenCV (heavy).",
      "dependencies": [
        {
          "name": "opencv4",
          "default-features": false,
          "features": [
            "jpeg",
            "png"
          ]
        }
      ]
    },
    "gui": {
      "description": "Dear ImGui + SDL3 GUI (Phase 4+).",
      "dependencies": [
        "sdl3",
        {
          "name": "imgui",
          "default-features": false,
          "features": [
            "docking-experimental",
            "sdl3-binding",
            "sdl3-renderer-binding"
          ]
        }
      ]
    },
    "spout": {
      "description": "Windows-only Spout texture sharing support (Phase 4+).",
      "supports": "windows",
      "dependencies": []
    },
    "lipsync": {
      "description": "Optional LivePortrait postprocessor (Python subprocess).",
      "dependencies": []
    }
  },
  "builtin-baseline": "22d9c655dc24ad24c6cac27607005e619ce46740"
}
